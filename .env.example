# Example environment configuration. Copy to `.env` and fill in real values.
#
#   cp .env.example .env
#
# `.env` is gitignored and MUST NOT be committed. Only the VITE_*-prefixed
# values below are exposed to the client bundle (safe to be public). Every
# other value is a server-only secret - never add a VITE_ prefix to a secret.

# ---------------------------------------------------------------------------
# Public client config (VITE_ prefix -> bundled into the browser app)
# These are safe to expose: the publishable/anon key is gated by Supabase RLS.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Server-readable mirrors of the public Supabase config (no VITE_ prefix).
# Some server handlers read these instead of the VITE_ versions.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-publishable-key
SUPABASE_PROJECT_ID=your-project-ref

# ---------------------------------------------------------------------------
# Server-only secrets (injected at deploy time - NEVER commit real values,
# NEVER add a VITE_ prefix; that would leak them into the client bundle).
# ---------------------------------------------------------------------------

# Supabase service-role key - bypasses RLS. Used only by *.server.ts handlers.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct Postgres connection string (contains the DB password).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Stripe (billing / checkout / webhooks).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ElevenLabs (text-to-speech for the /api/tts route).
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Lovable platform API key.
LOVABLE_API_KEY=your-lovable-api-key

# WordPress.com import API key.
WORDPRESS_COM_API_KEY=your-wordpress-com-api-key

# Web Push (VAPID) - notification delivery to browsers. Generate a P-256 pair
# with generateVapidKeys() from src/lib/notifications/webpush.server.ts.
# The public key is safe to expose (VITE_ prefix); the private key is NOT.
VAPID_PUBLIC_KEY=base64url-p256-public-key
VAPID_PRIVATE_KEY=base64url-p256-private-key
VAPID_SUBJECT=mailto:marketing@neweuropeanstrategies.com
VITE_VAPID_PUBLIC_KEY=base64url-p256-public-key

# Shared secret for POST /api/public/community-cron (push queue, e-mail
# digests, event reminders). Call it every 5-60 min from any scheduler.
COMMUNITY_CRON_SECRET=long-random-string

# ---------------------------------------------------------------------------
# Site URL (used to build absolute links in checkout, emails, etc.).
# The app reads the first of PUBLIC_SITE_URL / SITE_URL / URL that is set;
# in most hosting environments one of these is provided automatically.
# ---------------------------------------------------------------------------
PUBLIC_SITE_URL=https://your-domain.example
# SITE_URL=https://your-domain.example
# URL=https://your-domain.example
